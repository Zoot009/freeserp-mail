// Email Automation Platform — data model
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth / tenancy
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  projects     Project[]
}

model Project {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  apiKeys    ApiKey[]
  smtpConfig SmtpConfig?
  branding   Branding?
  contacts   Contact[]
  events     Event[]
  templates  EmailTemplate[]
  workflows  Workflow[]
  emailLogs  EmailLog[]

  @@index([userId])
}

model ApiKey {
  id         String    @id @default(cuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique // sha-256 of the raw key
  prefix     String // first chars shown in the UI, e.g. "ek_live_ab12"
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([projectId])
}

model SmtpConfig {
  id          String  @id @default(cuid())
  projectId   String  @unique
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  host        String
  port        Int     @default(587)
  secure      Boolean @default(false) // true for port 465
  username    String
  passwordEnc String // AES-256-GCM encrypted
  fromEmail   String
  fromName    String  @default("")

  updatedAt DateTime @updatedAt
}

// Global branding applied to every email at send time (header logo, colors,
// footer, sender). Change once → all templates inherit it.
model Branding {
  id              String  @id @default(cuid())
  projectId       String  @unique
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  brandName       String  @default("")
  logoUrl         String  @default("")
  brandColor      String  @default("#4f46e5")
  senderName      String  @default("")
  footerText      String  @default("")
  address         String  @default("")
  unsubscribeText String  @default("You're receiving this because you signed up.")
  socialInstagram String  @default("")
  socialX         String  @default("")
  socialLinkedin  String  @default("")
  updatedAt       DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Contacts & events
// ---------------------------------------------------------------------------

model Contact {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  email      String
  properties Json     @default("{}")
  subscribed Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  events       Event[]
  workflowRuns WorkflowRun[]
  emailLogs    EmailLog[]

  @@unique([projectId, email])
  @@index([projectId])
}

model Event {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  name       String
  properties Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([contactId])
}

// ---------------------------------------------------------------------------
// Templates
// ---------------------------------------------------------------------------

model EmailTemplate {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  subject   String
  html      String   @db.Text
  text      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailLogs EmailLog[]

  @@index([projectId])
}

// ---------------------------------------------------------------------------
// Workflows
// ---------------------------------------------------------------------------

enum WorkflowStatus {
  draft
  active
  paused
}

model Workflow {
  id           String         @id @default(cuid())
  projectId    String
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  triggerEvent String
  status       WorkflowStatus @default(draft)
  definition   Json           @default("{\"nodes\":[]}")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  runs WorkflowRun[]

  @@index([projectId])
  @@index([triggerEvent, status])
}

enum RunStatus {
  running
  completed
  failed
  cancelled
}

model WorkflowRun {
  id            String    @id @default(cuid())
  workflowId    String
  workflow      Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  contactId     String
  contact       Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status        RunStatus @default(running)
  currentNodeId String?
  context       Json      @default("{}") // event payload snapshot at trigger time
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  steps RunStepLog[]

  @@index([workflowId])
  @@index([contactId])
}

model RunStepLog {
  id          String      @id @default(cuid())
  runId       String
  run         WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId      String
  type        String
  status      String // scheduled | done | skipped | failed
  scheduledFor DateTime?
  executedAt  DateTime?
  result      Json        @default("{}")
  createdAt   DateTime    @default(now())

  @@index([runId])
}

// ---------------------------------------------------------------------------
// Email log
// ---------------------------------------------------------------------------

model EmailLog {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contactId      String
  contact        Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  templateId     String?
  template       EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  workflowRunId  String?
  subject        String
  status         String // queued | sent | failed
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([contactId])
}
